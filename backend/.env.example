# =====================================================
# VulnScan - Variables de Entorno
# =====================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores reales
# 3. NUNCA subas .env a GitHub (ya está en .gitignore)
# =====================================================

# ── Supabase (Base de datos) ──────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sentry (Monitoreo de errores) ─────────────────────
# Obtener en: sentry.io → tu proyecto → Settings → Client Keys
SENTRY_DSN=https://XXXXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Frontend URL (para CORS en producción) ────────────
# URL de tu Azure Static Web App
FRONTEND_URL=https://TU-APP.azurestaticapps.net

# ── Entorno ───────────────────────────────────────────
FLASK_ENV=development
